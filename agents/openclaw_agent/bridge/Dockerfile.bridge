FROM ros:humble-ros-base

# Install Python deps
RUN apt-get update && apt-get install -y python3-pip && rm -rf /var/lib/apt/lists/*
RUN pip3 install websocket-client

# Install Node.js for the openclaw-sdk bridge
RUN apt-get update && apt-get install -y curl && \
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y nodejs && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app/bridge
COPY package.json tsconfig.json ./
COPY forwarder_bridge.ts ./
RUN npm install && npx tsc

# Copy the forwarder Python script
WORKDIR /app
COPY perception_forwarder.py .
COPY perception_forwarder_ws.py .

ENV OPENCLAW_GATEWAY_URL=ws://openclaw:1455
ENV OPENCLAW_FORWARDER_BACKEND=sdk

CMD ["python3", "-c", "import os; backend = os.environ.get('OPENCLAW_FORWARDER_BACKEND', 'sdk'); exec(open('/app/perception_forwarder.py' if backend == 'sdk' else '/app/perception_forwarder_ws.py').read())"]
