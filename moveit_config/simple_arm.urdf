<?xml version="1.0"?>
<robot name="simple_arm">
  <link name="base_link">
    <visual>
      <geometry><box size="0.15 0.15 0.05"/></geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
  </link>
  <link name="shoulder_link">
    <visual>
      <geometry><box size="0.06 0.06 0.20"/></geometry>
      <origin rpy="0 0 0" xyz="0 0 0.10"/>
      <material name="blue"><color rgba="0.2 0.3 0.8 1"/></material>
    </visual>
  </link>
  <link name="upper_arm_link">
    <visual>
      <geometry><box size="0.05 0.05 0.25"/></geometry>
      <origin rpy="0 0 0" xyz="0 0 0.125"/>
      <material name="red"><color rgba="0.8 0.2 0.2 1"/></material>
    </visual>
  </link>
  <link name="forearm_link">
    <visual>
      <geometry><box size="0.04 0.04 0.25"/></geometry>
      <origin rpy="0 0 0" xyz="0 0 0.125"/>
      <material name="green"><color rgba="0.2 0.8 0.2 1"/></material>
    </visual>
  </link>
  <link name="gripper_link">
    <visual>
      <geometry><box size="0.08 0.03 0.03"/></geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="yellow"><color rgba="0.8 0.8 0.2 1"/></material>
    </visual>
  </link>
  <joint name="base_joint" type="revolute">
    <parent link="base_link"/><child link="shoulder_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.025"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="1" velocity="1"/>
  </joint>
  <joint name="shoulder_joint" type="revolute">
    <parent link="shoulder_link"/><child link="upper_arm_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.175"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="2.0" effort="1" velocity="1"/>
  </joint>
  <joint name="elbow_joint" type="revolute">
    <parent link="upper_arm_link"/><child link="forearm_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.25"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="2.0" effort="1" velocity="1"/>
  </joint>
  <joint name="gripper_joint" type="prismatic">
    <parent link="forearm_link"/><child link="gripper_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.25"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="0.05" effort="0.5" velocity="0.5"/>
  </joint>
</robot>
